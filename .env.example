# ============================================
# 智能视频制作系统 - 环境变量配置文件
# ============================================

# OpenRouter API密钥 - 用于LLM文本生成（推荐）
# 获取地址: https://openrouter.ai/
# 推荐模型: google/gemini-2.5-pro
OPENROUTER_API_KEY=你的OpenRouter_API密钥

# SiliconFlow API密钥 - 国内LLM服务商（备选）
# 获取地址: https://siliconflow.cn/
# Base URL: https://api.siliconflow.cn/v1/
# 支持模型: GLM-4.6, Kimi-K2-Instruct, Qwen3等
SILICONFLOW_KEY=你的SiliconFlow密钥

# 火山方舟API密钥 - 用于豆包图像生成（必需）
# 获取地址: https://console.volcengine.com/ark
# 推荐模型: : Seedream 4.0
SEEDREAM_API_KEY=你的火山引擎方舟API密钥

# 字节语音合成大模型配置 - 用于高质量TTS语音合成（必需）
# 获取地址: https://console.volcengine.com/
# 支持音色: zh_male_yuanboxiaoshu_moon_bigtts (默认可用)
BYTEDANCE_TTS_APPID=你的字节TTS_APPID
BYTEDANCE_TTS_ACCESS_TOKEN=你的字节TTS_ACCESS_TOKEN

# ============================================
# 【重要说明】根据你的使用配置，需要的最小API密钥组合：
# ============================================

# 方案1: 推荐配置（最佳体验）
# OPENROUTER_API_KEY + SEEDREAM_API_KEY + BYTEDANCE_TTS_*
# - LLM: OpenRouter (Gemini 2.5 Pro)
# - 图像: 豆包 Seedream 4.0  
# - 语音: 字节语音合成大模型

# 方案2: 国内服务配置
# SILICONFLOW_KEY + SEEDREAM_API_KEY + BYTEDANCE_TTS_*
# - LLM: SiliconFlow (GLM-4.6)
# - 图像: 豆包 Seedream 4.0
# - 语音: 字节语音合成大模型

# ============================================
# 云存储配置（Web版本）
# ============================================

# 存储提供商选择: aliyun_oss / tencent_cos / aws_s3 / local
# local: 本地存储（开发测试用）
# 生产环境建议使用云存储提供商以确保数据可靠性
STORAGE_PROVIDER=local

# ---------- 阿里云OSS配置 ----------
# 获取地址: https://oss.console.aliyun.com/
ALIYUN_OSS_ACCESS_KEY_ID=你的阿里云AccessKeyID
ALIYUN_OSS_ACCESS_KEY_SECRET=你的阿里云AccessKeySecret
ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_BUCKET=book-recap-storage

# ---------- 腾讯云COS配置 ----------
# 获取地址: https://console.cloud.tencent.com/cos
TENCENT_COS_SECRET_ID=你的腾讯云SecretId
TENCENT_COS_SECRET_KEY=你的腾讯云SecretKey
TENCENT_COS_REGION=ap-guangzhou
TENCENT_COS_BUCKET=book-recap-1234567890

# ---------- AWS S3配置 ----------
# 获取地址: https://console.aws.amazon.com/s3/
AWS_ACCESS_KEY=你的AWS_AccessKey
AWS_SECRET_KEY=你的AWS_SecretKey
AWS_REGION=us-west-2
AWS_S3_BUCKET=book-recap-storage

# ---------- 本地存储配置（开发环境）----------
LOCAL_STORAGE_DIR=./storage
LOCAL_STORAGE_URL=http://localhost:8000/files

# ============================================
# Web后端配置
# ============================================

# 数据库连接URL
DATABASE_URL=sqlite:///./book_recap.db

# Redis配置（Celery消息队列）
REDIS_URL=redis://localhost:6379/0