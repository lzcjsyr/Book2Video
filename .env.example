# ============================================
# 智能视频制作系统 - 环境变量示例
# 复制为 .env 后填入真实值；.env 已被 .gitignore 忽略。
# ============================================

# --------------------------------------------
# 1. LLM 与 生文 (文本大模型与创作服务)
# --------------------------------------------
# LLM 密钥（用于步骤1/2/3的脚本编写、要点提取、提示词脱敏等）
SILICONFLOW_KEY=你的SiliconFlow密钥
OPENROUTER_API_KEY=你的OpenRouter_API密钥
DEEPSEEK_API_KEY=你的DeepSeek_API密钥
MIMO_API_KEY=你的MIMO_API密钥
KIMI_API_KEY=你的Kimi/Moonshot_API密钥
VOLCENGINE_API_KEY=你的火山引擎方舟API密钥 

# --------------------------------------------
# 2. 生图 (图像大模型与视觉素材生成服务)
# --------------------------------------------
# 注：豆包-Seedream 生图服务直接复用第一部分定义的 VOLCENGINE_API_KEY，此处无需重复配置。

# Google Vertex AI / Gemini 图像生成服务
GOOGLE_CLOUD_API_KEY=你的Google_API密钥  # 仅当使用 "google" 方式（API Key 鉴权）时需要

# 以下两个参数仅当使用 "google_adc" 方式（Vertex AI 企业级认证 / 本地 gcloud ADC 鉴权）时需要
GOOGLE_CLOUD_PROJECT=你的Google_Cloud项目ID
GOOGLE_CLOUD_LOCATION=global

# --------------------------------------------
# 3. 生音 (语音合成与口播配音服务)
# --------------------------------------------
# 字节跳动语音合成大模型 (TTS) 
BYTEDANCE_TTS_API_KEY=你的字节TTS_API_KEY
BYTEDANCE_TTS_VOICE_ID=zh_male_jieshuoxiaoming_uranus_bigtts

# --------------------------------------------
# 4. 其他辅助服务 (研报/PDF精准解析)
# --------------------------------------------
# MinerU PDF 精准解析（仅复杂表格/研报类 PDF 抽取成文稿时需要）
MINERU_API_TOKEN=你的MinerU_API_TOKEN
